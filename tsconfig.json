{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2024"],
    "types": ["node"],
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "allowJs": true,
    "resolveJsonModule": true,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@core": ["./src/core/index.ts"],
      "@commands/*": ["./src/commands/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "scripts/**/*"]
}
