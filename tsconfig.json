{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2024"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@core": ["./src/core/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "scripts/**/*", "benchmark/**/*"]
}
