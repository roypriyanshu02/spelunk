{
  "name": "spelunk",
  "version": "0.1.1",
  "description": "AST-powered codebase indexer skill for coding agents. Parses repositories with Tree-sitter into a local SQLite index so agents trace dependency trees and locate symbols instantly instead of scanning raw files. Reduces token consumption by up to 90% with ~150ms resolution.",
  "keywords": [
    "github-copilot",
    "claude-code",
    "cursor",
    "ai-agent",
    "coding-agent",
    "tree-sitter",
    "sqlite",
    "ast",
    "codex",
    "devin",
    "cline",
    "opencode",
    "antigravity",
    "agent-skill",
    "skills-sh",
    "developer-tools",
    "llm-tools",
    "skill",
    "codebase-indexer",
    "codebase-navigation",
    "codebase-map",
    "dependency-tree",
    "symbol-resolution",
    "code-indexing",
    "token-optimization",
    "spelunk"
  ],
  "homepage": "https://github.com/roypriyanshu02/spelunk",
  "bugs": {
    "url": "https://github.com/roypriyanshu02/spelunk/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Priyanshu Roy",
    "url": "https://github.com/roypriyanshu02"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roypriyanshu02/spelunk.git"
  },
  "files": [
    "skills"
  ],
  "type": "module",
  "scripts": {
    "build": "node --experimental-strip-types scripts/build.ts",
    "init": "npm run build",
    "test": "vitest run",
    "benchmark": "node --experimental-strip-types benchmark/benchmark.ts",
    "eval": "node --experimental-strip-types benchmark/agentic_eval.ts",
    "lint": "tsc --noEmit && oxlint --ignore-path .prettierignore",
    "format": "oxfmt --write --ignore-path .prettierignore"
  },
  "dependencies": {
    "ignore": "^7.0.6",
    "tsconfig-paths": "^4.2.0",
    "web-tree-sitter": "^0.22.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "js-tiktoken": "^1.0.12",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tree-sitter-wasms": "^0.1.13",
    "tsdown": "^0.22.7",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.18.0",
    "npm": ">=11.16.0"
  }
}
