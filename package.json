  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tree-sitter-wasms": "^0.1.13",
    "tsdown": "^0.22.7",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10"
  }
