{
  "name": "spelunk",
  "version": "0.2.1",
  "description": "AST-based codebase indexer skill for coding agents. Parses repositories with Tree-sitter into a local SQLite index to trace dependency trees and locate symbols without scanning raw files.",
  "keywords": [
    "agent-skill",
    "ai-agent",
    "antigravity",
    "ast",
    "claude-code",
    "codebase-indexer",
    "codebase-navigation",
    "coding-agent",
    "context-management",
    "cursor",
    "dependency-tree",
    "developer-tools",
    "github-copilot",
    "llm-tools",
    "skills-sh",
    "sqlite",
    "symbol-resolution",
    "token-optimization",
    "tree-sitter",
    "typescript"
  ],
  "homepage": "https://github.com/roypriyanshu02/spelunk",
  "bugs": {
    "url": "https://github.com/roypriyanshu02/spelunk/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Priyanshu Roy",
    "url": "https://github.com/roypriyanshu02"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roypriyanshu02/spelunk.git"
  },
  "files": [
    "skills"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown && node --experimental-strip-types scripts/build.ts",
    "watch": "tsdown --watch",
    "test": "vitest run",
    "benchmark": "node --experimental-strip-types benchmark/benchmark.ts",
    "eval": "node --experimental-strip-types benchmark/agentic_eval.ts",
    "lint": "oxlint --ignore-path .prettierignore",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^26.1.1",
    "ignore": "^7.0.6",
    "js-tiktoken": "^1.0.12",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tree-sitter-wasms": "^0.1.13",
    "tsconfig-paths": "^4.2.0",
    "tsdown": "^0.22.7",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10",
    "web-tree-sitter": "0.23.2"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
